<?php
    class Monly_Buy_Tea{

    	private $conn;
        private $table_name ='daily_tea_buy';
        function __construct($db){
            $this->conn = $db;
        }
        public function Select_Daily_Products_Monthly($request){
        	$month=$request["month_name"];
        	$type=$request["tea_type"];
            $year=$request["year"];
        	$limit = '10';
            $page = 1;
            if((int)$request["page"] > 1)
            {
              $val=(((int)$request["page"])-1);
              $start = ($val * $limit);
              $page = (int)$request["page"];
              $row_number=(($page-1)*(int)$limit)+1;
            }
            else
            {
              $start = 0;
              $row_number=1;
            } 
            $check_type='';
        	if($type==0){
        		$select="SELECT id,SUM(d_product_amount) as d_product_amount,SUM(d_todal_price) as d_todal_price,daily_create,d_type FROM ".$this->table_name." WHERE MONTH(daily_create)='$month' AND YEAR(daily_create)='$year' GROUP BY daily_create ";
        		$count="SELECT COUNT(id),SUM(d_product_amount) as total_amount,SUM(d_todal_price) as total_price FROM ".$this->table_name." WHERE MONTH(daily_create)='$month' AND YEAR(daily_create)='$year'";
        		$check_type="all type";
        	}else{
        		$type=(int)$type-1;
        		$select="SELECT * FROM ".$this->table_name." WHERE MONTH(daily_create)='$month' AND d_type='$type' AND YEAR(daily_create)='$year'";
        		$count="SELECT COUNT(id),SUM(d_product_amount) as total_amount,SUM(d_todal_price) as total_price FROM ".$this->table_name." WHERE MONTH(daily_create)='$month' AND d_type='$type' AND YEAR(daily_create)='$year'";
        	}
        	$filter_query = $select . 'LIMIT '.$start.', '.$limit.'';
            $statement = $this->conn->prepare($select);
            $statement->execute();
            $total_data = $statement->rowCount();
            $statement = $this->conn->prepare($filter_query);
            $statement->execute();
            $result = $statement->fetchAll();
            $calculate = $this->conn->prepare($count);
            $calculate->execute();
            $count_value= $calculate->fetchAll();
            $pagnation_no=ceil($total_data/$limit);
            if($result){
            	return array("result"=>$result,"page"=>$request["page"],"total"=>$count_value,"type"=>$check_type,"pagination"=>$pagnation_no);
            }else{
            	return array("result"=>"0");
            }
        }
        public function Delete_Product_Monthly($request){
            $product_id=$request["prodcut_id"];
            $delete="DELETE FROM ".$this->table_name." WHERE id='$product_id'";
            $statement_delete = $this->conn->prepare($delete);
            $result=$statement_delete->execute();
            if($result){
                return 1;
            }else{
                return 0;
            }
        }
        public function Detail_Product_By_Daily($request){
            $limit = '10';
            $date=$request["date"];
            $type=$request["product_type"];
            $page = 1;
            if((int)$request["page"] > 1)
            {
              $val=(((int)$request["page"])-1);
              $start = ($val * $limit);
              $page = (int)$request["page"];
              $row_number=(($page-1)*(int)$limit)+1;
            }
            else
            {
              $start = 0;
              $row_number=1;
            }
            if($type==0){
                $query="SELECT * FROM tea WHERE DATE(create_date)='$date'";
                $sum="SELECT SUM(product_amount) as total_amount,SUM(total) as total_price FROM tea  WHERE DATE(create_date)='$date'";
            }else{
                $type=$type-1;
                $query="SELECT * FROM tea WHERE product_type='$type' AND DATE(create_date)='$date'";
                $sum="SELECT SUM(product_amount) as total_amount,SUM(total) as total_price FROM tea  WHERE product_type='$type' AND DATE(create_date)='$date'";
            }
            $filter_query = $query . 'LIMIT '.$start.', '.$limit.'';
            $statement = $this->conn->prepare($query);
            $statement->execute();
            $total_data = $statement->rowCount();
            $statement = $this->conn->prepare($filter_query);
            $statement->execute();
            $result = $statement->fetchAll();
            $sum_val = $this->conn->prepare($sum);
            $sum_result=$sum_val->execute();
            $result_sum_value=$sum_val->fetch();
            $pagnation_no=ceil($total_data/$limit);
            if(isset($result)){
                return array("result"=>$result,"pagnation"=>$pagnation_no,"page"=>$request["page"],"total"=>$total_data,"sum_value"=>$result_sum_value);
            }else{
                return array("result"=>"0");
            }
        }
    }

?>