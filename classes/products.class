<?php
    class Create_Products{

    	private $conn;
        private $table_name ='tea';
        function __construct($db){
            $this->conn = $db;
        }

        public function Create_Products_Buy_Daily($request){
        	$user_id=$request["user_id"];
        	$customer_name=$request["customer_name"];
        	$product_type=$request["product_type"];
        	$valliage_name=$request["valliage_name"];
        	$product_amount=$request["product_amount"];
        	$product_price=$request["product_price"];
        	$total_price=$request["total_price"];

        	$query="INSERT INTO ".$this->table_name." (user_id,customer_name,product_type,	valliage_name,product_amount,product_price,	total) VALUES ('$user_id','$customer_name','$product_type','$valliage_name','$product_amount','$product_price','$total_price')";
            $insert = $this->conn->prepare($query);
            $data=$insert->execute();
            if($data){
            	return 1;
            }
        }

        public function Select_By_Today_Date($request){
            $date=$request["create_date"];
            $limit = '10';
            $page = 1;
            if((int)$request["page"] > 1)
            {
              $val=(((int)$request["page"])-1);
              $start = ($val * $limit);
              $page = (int)$request["page"];
              $row_number=(($page-1)*(int)$limit)+1;
            }
            else
            {
              $start = 0;
              $row_number=1;
            }
            $query="SELECT * FROM ".$this->table_name." WHERE  DATE(create_date)='$date'";
            $filter_query = $query . 'LIMIT '.$start.', '.$limit.'';
            $statement = $this->conn->prepare($query);
            $statement->execute();
            $total_data = $statement->rowCount();
            $statement = $this->conn->prepare($filter_query);
            $statement->execute();
            $result = $statement->fetchAll();
            $pagnation_no=ceil($total_data/$limit);
            return array("result"=>$result,"pagnation"=>$pagnation_no,"page"=>$request["page"]);
        }
    }
?>