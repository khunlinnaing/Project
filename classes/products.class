<?php
    class Create_Products{

    	private $conn;
        private $table_name ='tea';
        function __construct($db){
            $this->conn = $db;
        }

        public function Create_Products_Buy_Daily($request){
        	$user_id=$request["user_id"];
        	$customer_name=$request["customer_name"];
        	$product_type=$request["product_type"];
        	$valliage_name=$request["valliage_name"];
        	$product_amount=$request["product_amount"];
        	$product_price=$request["product_price"];
        	$total_price=$request["total_price"];

        	$query="INSERT INTO ".$this->table_name." (user_id,customer_name,product_type,	valliage_name,product_amount,product_price,	total) VALUES ('$user_id','$customer_name','$product_type','$valliage_name','$product_amount','$product_price','$total_price')";
            $insert = $this->conn->prepare($query);
            $data=$insert->execute();
            if($data){
            	return 1;
            }
        }

        public function Select_By_Today_Date($request){
            $date=$request["create_date"];
            $limit = '20';
            $page = 1;
            if((int)$request["page"] > 1)
            {
              $val=(((int)$request["page"])-1);
              $start = ($val * $limit);
              $page = (int)$request["page"];
              $row_number=(($page-1)*(int)$limit)+1;
            }
            else
            {
              $start = 0;
              $row_number=1;
            }
            if(isset($request["customer_name"]) && $request["product_type"] == 0){
                $search=$request['customer_name'];
                $searchq=preg_replace("#[^0-9a-zA-z -/\u1031]#i","",$search);
                $query="SELECT * FROM ".$this->table_name." WHERE customer_name LIKE '%$searchq%' AND DATE(create_date)='$date'";
                $sum="SELECT SUM(product_amount) as total_amount,SUM(total) as total_price FROM ".$this->table_name." WHERE customer_name LIKE '%$searchq%' AND DATE(create_date)='$date'";
            }else if(isset($request["customer_name"]) && $request["product_type"] != 0){
                $search=$request['customer_name'];
                $product_type=((integer)$request['product_type']-1);
                $searchq=preg_replace("#[^0-9a-zA-z -/\u1031]#i","",$search);
                $query="SELECT * FROM ".$this->table_name." WHERE customer_name LIKE '%$searchq%' AND DATE(create_date)='$date' AND product_type='$product_type'";
                $sum="SELECT SUM(product_amount) as total_amount,SUM(total) as total_price FROM ".$this->table_name." WHERE customer_name LIKE '%$searchq%' AND  DATE(create_date)='$date' AND product_type='$product_type'";
            }else{
                $query="SELECT * FROM ".$this->table_name." WHERE  DATE(create_date)='$date'";
                $sum="SELECT SUM(product_amount) as total_amount,SUM(total) as total_price FROM ".$this->table_name." WHERE  DATE(create_date)='$date'";
            }
            $filter_query = $query . 'LIMIT '.$start.', '.$limit.'';
            $statement = $this->conn->prepare($query);
            $statement->execute();
            $total_data = $statement->rowCount();
            $statement = $this->conn->prepare($filter_query);
            $statement->execute();
            $result = $statement->fetchAll();
            $sum_val = $this->conn->prepare($sum);
            $sum_result=$sum_val->execute();
            $result_sum_value=$sum_val->fetch();
            $pagnation_no=ceil($total_data/$limit);
            if(isset($result)){
                return array("result"=>$result,"pagnation"=>$pagnation_no,"page"=>$request["page"],"total"=>$total_data,"sum_value"=>$result_sum_value);
            }else{
                return array("result"=>"0");
            }
            
        }
        public function Save_To_Daily_Table($request){
            $today_date=$request["date"];
            $user_id=$request["user_id"];
            $query="SELECT product_type,SUM(product_amount) as d_product_amount,SUM(total) as d_total FROM ".$this->table_name." WHERE DATE(create_date)='$today_date' GROUP BY product_type";
            $data = $this->conn->prepare($query);
            $value=$data->execute();
            $result = $data->fetchAll();
            if($result){
                return $result;
            }
        }
    }
?>
